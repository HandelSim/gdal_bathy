CONFIG_VERSION=3.12.2
CONFIG_INST_PREFIX=C:/gdal-minimal
CONFIG_INST_LIBS=-LIBPATH:C:/gdal-minimal/lib gdal
CONFIG_INST_CFLAGS=-IC:/gdal-minimal/include
CONFIG_INST_DATA=C:/gdal-minimal/share/gdal
prefix=${CONFIG_INST_PREFIX}
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${exec_prefix}/include
datadir=${CONFIG_INST_DATA}

Name: libgdal
Description: Geospatial Data Abstraction Library
Version: ${CONFIG_VERSION}
Libs: ${CONFIG_INST_LIBS}
Libs.private: C:/vcpkg/installed/x64-windows/lib/iconv.lib C:/vcpkg/installed/x64-windows/lib/charset.lib legacy_stdio_definitions.lib odbccp32.lib C:/vcpkg/installed/x64-windows/lib/libssl.lib C:/vcpkg/installed/x64-windows/lib/libcrypto.lib crypt32 C:/vcpkg/installed/x64-windows/lib/zstd.lib C:/vcpkg/installed/x64-windows/lib/lzma.lib C:/vcpkg/installed/x64-windows/lib/lz4.lib wbemuuid C:/vcpkg/installed/x64-windows/lib/qhull_r.lib C:/vcpkg/installed/x64-windows/lib/libexpat.lib C:/vcpkg/installed/x64-windows/lib/jpeg.lib C:/vcpkg/installed/x64-windows/lib/geotiff_i.lib C:/vcpkg/installed/x64-windows/lib/tiff.lib C:/vcpkg/installed/x64-windows/lib/hdf5.lib shlwapi C:/vcpkg/installed/x64-windows/lib/libxml2.lib C:/vcpkg/installed/x64-windows/lib/geos_c.lib psapi C:/vcpkg/installed/x64-windows/lib/proj.lib C:/vcpkg/installed/x64-windows/lib/json-c.lib C:/vcpkg/installed/x64-windows/lib/zlib.lib
Cflags: ${CONFIG_INST_CFLAGS}
