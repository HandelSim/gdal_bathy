#!/bin/sh
CONFIG_LIBS="-LIBPATH:C:/gdal-minimal/lib gdal"
CONFIG_DEP_LIBS="C:/vcpkg/installed/x64-windows/lib/iconv.lib C:/vcpkg/installed/x64-windows/lib/charset.lib legacy_stdio_definitions.lib odbccp32.lib C:/vcpkg/installed/x64-windows/lib/libssl.lib C:/vcpkg/installed/x64-windows/lib/libcrypto.lib crypt32 C:/vcpkg/installed/x64-windows/lib/zstd.lib C:/vcpkg/installed/x64-windows/lib/lzma.lib C:/vcpkg/installed/x64-windows/lib/lz4.lib wbemuuid C:/vcpkg/installed/x64-windows/lib/qhull_r.lib C:/vcpkg/installed/x64-windows/lib/libexpat.lib C:/vcpkg/installed/x64-windows/lib/jpeg.lib C:/vcpkg/installed/x64-windows/lib/geotiff_i.lib C:/vcpkg/installed/x64-windows/lib/tiff.lib C:/vcpkg/installed/x64-windows/lib/hdf5.lib shlwapi C:/vcpkg/installed/x64-windows/lib/libxml2.lib C:/vcpkg/installed/x64-windows/lib/geos_c.lib psapi C:/vcpkg/installed/x64-windows/lib/proj.lib C:/vcpkg/installed/x64-windows/lib/json-c.lib C:/vcpkg/installed/x64-windows/lib/zlib.lib"
CONFIG_PREFIX="C:/gdal-minimal"
CONFIG_CFLAGS="-IC:/gdal-minimal/include"
CONFIG_DATA="C:/gdal-minimal/share/gdal"
CONFIG_VERSION="3.12.2"
CONFIG_GNM_ENABLED=yes
CONFIG_FORMATS="GTIFF MEM vrt XYZ HDF5 GeoJSON Shape"
CONFIG_PLUGINDIR="C:/gdal-minimal/lib/gdalplugins"
usage()

{
	cat <<EOF
Usage: gdal-config [OPTIONS]
Options:
	[--prefix[=DIR]]
	[--libs]
	[--dep-libs]
	[--cflags]
	[--datadir]
	[--version]
	[--ogr-enabled]
	[--gnm-enabled]
	[--formats]
	[--plugindir]
EOF
	exit $1
}

if test $# -eq 0; then
	usage 1 1>&2
fi

case $1 in
  --libs)
    echo $CONFIG_LIBS
    ;;

  --dep-libs)
    echo $CONFIG_DEP_LIBS
    ;;

  --cflags)
    echo $CONFIG_CFLAGS
    ;;

  --datadir)
    echo $CONFIG_DATA
    ;;

  --prefix)
    echo $CONFIG_PREFIX
    ;;

  --version)
    echo $CONFIG_VERSION
    ;;

  --ogr-enabled)
    echo yes
    ;;

  --gnm-enabled)
    echo $CONFIG_GNM_ENABLED
    ;;

  --formats)
    echo $CONFIG_FORMATS
    ;;

  --plugindir)
    echo $CONFIG_PLUGINDIR
    ;;

  *)
    usage 1 1>&2
    ;;

esac
